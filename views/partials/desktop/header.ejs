

<header>
  <div class="navbar">
    <a href="/" class="logo-link">
      <img src="/images/biobrain-logo.png" alt="BioBrain" id="logo">
    </a>

    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/leaderboard">Leaderboard</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/admin">Admin</a></li>

      <% if (session && session.user) { %>
        <li class="nav-user">
          <div class="user-menu" id="userMenu">
            <div class="user-trigger">
              <div class="user-avatar">
                <%= session.user.username.charAt(0).toUpperCase() %>
              </div>
              <span class="desktop-inline-3j05yt">&#9662;</span>
            </div>

            <div class="dropdown">
              <div class="dropdown-header">
                <span class="dropdown-username">
                  <%= session.user.username %>
                </span>
                <span class="dropdown-email">
                  <%= session.user.email %>
                </span>
              </div>
              <a href="/user/profile" class="dropdown-item">👤 Profile</a>
              <a href="/authentication/logout" class="dropdown-item logout">🚪 Logout</a>
            </div>
          </div>
        </li>
        <% } else { %>
          <li><a href="/authentication/login" class="btn-navbar">Login</a></li>
          <% } %>
    </ul>
  </div>
</header>

<script>
  // Logic for toggling dropdown and closing on click-outside
  document.addEventListener('DOMContentLoaded', () => {
    const userMenu = document.getElementById('userMenu');

    if (userMenu) {
      userMenu.addEventListener('click', (e) => {
        userMenu.classList.toggle('active');
        e.stopPropagation();
      });

      document.addEventListener('click', () => {
        userMenu.classList.remove('active');
      });
    }
  });
</script>