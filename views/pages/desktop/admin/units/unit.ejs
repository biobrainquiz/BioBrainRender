<!DOCTYPE html>
<html>

<head>

<title>Admin Dashboard - Units</title>

<link rel="stylesheet" href="/css/adminStyle.css">



</head>

<body class="view-pages-desktop-admin-units-unit">

<%- include('../../../../partials/admin/header') %>

<div class="admin-container">

<%- include('../../../../partials/admin/sidebar') %>

<main class="admin-content">

<div class="unit-wrapper">

<div class="page-header">
<h2>📂 Unit Management</h2>
</div>

<div class="table-card">

<table>

<thead>

<tr class="header-row">

<th>#</th>

<th>
Exam Code
<button class="sort-btn" onclick="sortTable(1)">⇅</button>
</th>

<th>
Exam Name
<button class="sort-btn" onclick="sortTable(2)">⇅</button>
</th>

<th>
Subject Code
<button class="sort-btn" onclick="sortTable(3)">⇅</button>
</th>

<th>
Subject Name
<button class="sort-btn" onclick="sortTable(4)">⇅</button>
</th>

<th>
Unit Code
<button class="sort-btn" onclick="sortTable(5)">⇅</button>
</th>

<th>
Unit Name
<button class="sort-btn" onclick="sortTable(6)">⇅</button>
</th>

<th>
Created
<button class="sort-btn" onclick="sortTable(7)">⇅</button>
</th>

<th class="center">Actions</th>

</tr>


<tr class="filter-row">

<th></th>

<th>
<select id="filterExamCode" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
<select id="filterExamName" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
<select id="filterSubjectCode" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
<select id="filterSubjectName" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
<select id="filterUnitCode" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
<select id="filterUnitName" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
<select id="filterCreated" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th></th>

</tr>

</thead>

<tbody id="unitTableBody">

<% units.forEach((unit,index)=>{ %>

<tr data-id="<%= unit._id %>">

<td class="center row-number"><%= index+1 %></td>

<td><%= unit.exam?.examcode %></td>

<td><%= unit.exam?.examname %></td>

<td><%= unit.subject?.subjectcode %></td>

<td><%= unit.subject?.subjectname %></td>

<td><%= unit.unitcode %></td>

<td class="unitname"><%= unit.unitname %></td>

<td><%= new Date(unit.createdAt).toLocaleDateString() %></td>

<td class="center action-buttons">

<button class="edit-btn" onclick="enableEdit(this)">Edit</button>

<button class="save-btn admin-inline-rzfzxc" onclick="saveUnit(this)">
Save
</button>

<button class="cancel-btn admin-inline-rzfzxc" onclick="cancelEdit(this)">
Cancel
</button>

<button class="delete-btn" onclick="deleteUnit('<%= unit._id %>')">
Delete
</button>

</td>

</tr>

<% }) %>


<tr id="insertRow" class="add-row">

<td class="center">+</td>

<td id="newExamCode"></td>

<td>

<select id="examSelect" onchange="examChanged()">

<option value="">Select Exam</option>

<% exams.forEach(exam=>{ %>

<option value="<%= exam._id %>" data-code="<%= exam.examcode %>">
<%= exam.examname %>
</option>

<% }) %>

</select>

</td>

<td id="newSubjectCode"></td>

<td>

<select id="subjectSelect" onchange="subjectChanged()">
<option value="">Select Subject</option>
</select>

</td>

<td>
<input id="unitCodeInput" placeholder="Unit Code">
</td>

<td>
<input id="unitNameInput" placeholder="Unit Name">
</td>

<td>--</td>

<td class="center">
<button class="add-btn" onclick="insertUnit()">Add</button>
</td>

</tr>

</tbody>

</table>

</div>

</div>

</main>

</div>

<%- include('../../../../partials/admin/footer') %>

<script>

const subjects = <%- JSON.stringify(subjects) %>;

let sortDirection={};

function refreshRowNumbers(){

const rows=document.querySelectorAll("#unitTableBody tr");

let i=1;

rows.forEach(row=>{
if(row.style.display!=="none" && !row.id){
row.querySelector(".row-number").innerText=i++;
}
});

}

function buildFilters(){

const rows=document.querySelectorAll("#unitTableBody tr");

const sets=[new Set(),new Set(),new Set(),new Set(),new Set(),new Set(),new Set()];

rows.forEach(row=>{

if(row.id==="insertRow") return;

for(let i=1;i<=7;i++)
sets[i-1].add(row.children[i].innerText.trim());

});

fillDropdown("filterExamCode",sets[0]);
fillDropdown("filterExamName",sets[1]);
fillDropdown("filterSubjectCode",sets[2]);
fillDropdown("filterSubjectName",sets[3]);
fillDropdown("filterUnitCode",sets[4]);
fillDropdown("filterUnitName",sets[5]);
fillDropdown("filterCreated",sets[6]);

}

function fillDropdown(id,set){

const select=document.getElementById(id);
const current=select.value;

select.innerHTML='<option value="">All</option>';

Array.from(set).sort().forEach(v=>{
const opt=document.createElement("option");
opt.value=v;
opt.textContent=v;
select.appendChild(opt);
});

select.value=current;

}

function applyFilters(){

const filters=[
filterExamCode.value,
filterExamName.value,
filterSubjectCode.value,
filterSubjectName.value,
filterUnitCode.value,
filterUnitName.value,
filterCreated.value
];

const rows=document.querySelectorAll("#unitTableBody tr");

rows.forEach(row=>{

if(row.id==="insertRow") return;

let visible=true;

filters.forEach((f,i)=>{
if(f && row.children[i+1].innerText!==f)
visible=false;
});

row.style.display=visible?"":"none";

});

refreshRowNumbers();

}

function sortTable(col){

const table=document.getElementById("unitTableBody");

const rows=Array.from(table.querySelectorAll("tr")).filter(r=>r.id!=="insertRow");

sortDirection[col]=!sortDirection[col];

rows.sort((a,b)=>{

let A=a.children[col].innerText.toLowerCase();
let B=b.children[col].innerText.toLowerCase();

if(A<B) return sortDirection[col]?-1:1;
if(A>B) return sortDirection[col]?1:-1;

return 0;

});

rows.forEach(r=>table.appendChild(r));

table.appendChild(document.getElementById("insertRow"));

refreshRowNumbers();
buildFilters();

}

function examChanged(){

const exam=document.getElementById("examSelect");
const code=exam.selectedOptions[0]?.dataset.code;

document.getElementById("newExamCode").innerText=code||"";

const subjectSelect=document.getElementById("subjectSelect");

subjectSelect.innerHTML='<option value="">Select Subject</option>';

subjects.forEach(s=>{

if(s.exam._id===exam.value){

const opt=document.createElement("option");

opt.value=s._id;
opt.dataset.code=s.subjectcode;
opt.textContent=s.subjectname;

subjectSelect.appendChild(opt);

}

});

}

function subjectChanged(){

const sub=document.getElementById("subjectSelect");
const code=sub.selectedOptions[0]?.dataset.code;

document.getElementById("newSubjectCode").innerText=code||"";

}

async function insertUnit(){

const selectedExam=document.getElementById("examSelect");
const examOption=selectedExam.options[selectedExam.selectedIndex];

const examId=examOption.value;
const examCode=examOption.dataset.code;

const selectedSubject=document.getElementById("subjectSelect");
const subjectOption=selectedSubject.options[selectedSubject.selectedIndex];

const subjectId=subjectOption.value;
const subjectCode=subjectOption.dataset.code;

const unitcode=document.getElementById("unitCodeInput").value;
const unitname=document.getElementById("unitNameInput").value;

const res=await fetch("/admin/units/create",{

method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({examCode,subjectCode,unitcode,unitname,examId,subjectId})

});

const data=await res.json();

if(data.success) location.reload();
else alert(data.message);

}

function enableEdit(btn){

const row = btn.closest("tr");

const cell = row.querySelector(".unitname");
const oldValue = cell.innerText.trim();

cell.innerHTML = `<input class="edit-input" value="${oldValue}">`;

row.querySelector(".edit-btn").style.display="none";
//row.querySelector(".delete-btn").style.display="none";

row.querySelector(".save-btn").style.display="inline";
row.querySelector(".cancel-btn").style.display="inline";

row.querySelector(".edit-input").focus();

}


function cancelEdit(btn){

const row = btn.closest("tr");
const cell = row.querySelector(".unitname");

const input = row.querySelector(".edit-input");
const original = input.defaultValue;

cell.innerText = original;

row.querySelector(".edit-btn").style.display="inline";
row.querySelector(".delete-btn").style.display="inline";

row.querySelector(".save-btn").style.display="none";
row.querySelector(".cancel-btn").style.display="none";

}


async function saveUnit(btn){

const row = btn.closest("tr");
const id = row.dataset.id;

const input = row.querySelector(".edit-input");
const newName = input.value.trim();

if(!newName){
alert("Unit name cannot be empty");
return;
}

const res = await fetch(`/admin/units/update/${id}`,{

method:"POST",
headers:{"Content-Type":"application/json"},
body:JSON.stringify({unitname:newName})

});

const data = await res.json();

if(data.success){

row.querySelector(".unitname").innerText = newName;

row.querySelector(".edit-btn").style.display="inline";
row.querySelector(".delete-btn").style.display="inline";

row.querySelector(".save-btn").style.display="none";
row.querySelector(".cancel-btn").style.display="none";

buildFilters();

}
else{

alert("Update failed");

}

}

async function deleteUnit(id){

if(!confirm("Delete this unit?")) return;

await fetch("/admin/units/"+id,{method:"DELETE"});

location.reload();

}

document.addEventListener("DOMContentLoaded",buildFilters);

</script>

</body>
</html>