<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BioBrain - Email Verified</title>
  <link rel="stylesheet" href="/css/desktopStyle.css" />
  
</head>

<body class="view-pages-desktop-verify-success">
  <%- include('../../partials/desktop/header') %>

  <div class="login-container">
    <div class="success-container">
      <div class="success-icon">✓</div>
      <h2>Email Verified!</h2>
      <p class="desktop-inline-1l22c5u">
        Your account has been successfully activated. You can now access all BioBrain features.
      </p>

      <div class="action-buttons">
        <button id="loginBtn" class="btn-primary" onclick="window.location.href='/authentication/login'">Go to Login</button>
        <button id="homeBtn" class="btn-secondary" onclick="window.location.href='/'">Return Home</button>
      </div>
    </div>
  </div>

  <%- include('../../partials/desktop/footer') %>
</body>

</html>