<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>Quiz Results | BioBrain</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="/js/ui-helper.js"></script>

  
  <link rel="stylesheet" href="/css/desktopStyle.css" />
</head>
<body class="desktop-quizresults-page">

<header>
    <h1>BioBrain - Quiz Results</h1>
    <div class="header-actions desktop-quizresults-header-actions">
      <a href="/" class="home-btn desktop-quizresults-home-btn">🏠 Home</a>
      <a href="javascript:void(0)"    onclick="downloadPdfReport('<%= examSession.resultid %>')"    title="Get PDF of Your Result">
          <i class="fa-solid fa-file-pdf desktop-quizresults-fa-solid desktop-quizresults-fa-file-pdf"></i>PDF
      </a>
      <a href="javascript:void(0)"    onclick="sendEmailReport('<%= examSession.resultid %>')"    title="Send Result via Email">  
          <i class="fa-solid fa-envelope desktop-quizresults-fa-solid desktop-quizresults-fa-envelope"></i> Email
      </a>
    </div>
</header>
<div class="container desktop-quizresults-container">

    <div class="greeting desktop-quizresults-greeting">
      Hello, <strong>
        <%= examSession.username ? examSession.username : 'Guest' %>
      </strong>!
    </div>

    <table class="stats-table desktop-quizresults-stats-table">
      <tr>
        <th>Total Questions</th>
        <th>Attempted</th>
        <th>Correct</th>
        <th>Wrong</th>
        <th>Score</th>
      </tr>
      <tr>
        <td>
          <%= examSession.questionscount %>
        </td>
        <td>
          <%= examSession.attempted %>
        </td>
        <td class="correct desktop-quizresults-correct">
          <%= examSession.right %>
        </td>
        <td class="wrong desktop-quizresults-wrong">
          <%= examSession.wrong %>
        </td>
        <td>
          <%= examSession.finalscore %>
        </td>
      </tr>
    </table>

    <div class="desktop-quizresults-inline-01">

  <!-- Analyse This Quiz -->
  <button class="ai-btn desktop-quizresults-ai-btn"
    onclick="<%= examSession.isuserpremium ? 'analyzeQuiz(this)' : 'return false;' %>"
    <%- !examSession.isuserpremium ? 'disabled title="Premium Feature: Upgrade to access"' : '' %>
    data-resultid="<%= examSession.resultid %>">
    📄 Analyse This Quiz
  </button>

  <!-- Analyse All Quizzes -->
  <button class="ai-btn desktop-quizresults-ai-btn"
    onclick="<%= examSession.isuserpremium ? 'analyzeAll(this)' : 'return false;' %>"
    <%- !examSession.isuserpremium ? 'disabled title="Premium Feature: Upgrade to access"' : '' %>
    data-userid="<%= examSession.userid %>">
    📊 Analyse All Quizzes
  </button>

</div>

<!-- AI Summary Output -->
<div id="ai-summary" class="ai-response desktop-quizresults-ai-response"></div>
    <h2>Question Review</h2>
    <% examSession.questions.forEach((q, idx)=> {
      const userAns = examSession.answers[q._id]; %>
      <div class="question-box desktop-quizresults-question-box">
        <p><strong>Q<%= idx + 1 %>:</strong>
          <%= q.question %>
        </p>

        <ul class="question-options desktop-quizresults-question-options">
          <% ['opt1', 'opt2' , 'opt3' , 'opt4' ].forEach((optKey, i)=> {
            const optionNum = i + 1;
            let cls = '';
            if (userAns) {
            cls = (userAns == optionNum && optionNum == q.answer) ? 'correct'
            : (userAns == optionNum && optionNum != q.answer) ? 'wrong' : '';
            }
            if (!userAns) cls = 'unattempted';
            %>
            <li class="<%= cls %>">
              <strong>
                <%= String.fromCharCode(65 + i) %>.
              </strong>
              <%= q[optKey] %>
            </li>
            <% }) %>
        </ul>

        <p>Correct Answer: <strong>
            <%= ['A','B','C','D'][q.answer-1] %>
          </strong></p>
        <% if(!userAns){ %>
          <p class="unattempted desktop-quizresults-unattempted">You did not attempt this question.</p>
          <% } %>

            <!-- 🤖 AI BUTTON -->
            <button class="ai-btn desktop-quizresults-ai-btn" onclick="<%= examSession.isuserpremium ? 'explainAnswer(this)' : 'return false;' %>"
              <%- !examSession.isuserpremium ? 'disabled title="Premium Feature: Upgrade to access"' : '' %>
              data-question="<%= q.question %>"
                data-opt1="<%= q.opt1 %>"
                  data-opt2="<%= q.opt2 %>"
                    data-opt3="<%= q.opt3 %>"
                      data-opt4="<%= q.opt4 %>"
                        data-correct="<%= q.answer %>"
                          data-user="<%= (userAns===undefined || userAns===null) ? -1 : userAns %>">
                            🤖 Explain Answer
            </button>

            <div class="ai-response desktop-quizresults-ai-response"></div>

      </div>
      <% }) %>
</div>

<script>
    // Wrap in a check to ensure BioBrainUI is ready
  async function downloadPdfReport(id) {
    if (typeof BioBrainUI === 'undefined') return console.error("Helper not loaded");
    
    BioBrainUI.showLoading('Generating PDF', 'Preparing your performance analytics...');
    try {
        const response = await fetch(`/mocktest/result/pdf/${id}`);
        if (!response.ok) throw new Error();
        const blob = await response.blob();
        
        BioBrainUI.finish();
        
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `BioBrain_Report_${id}.pdf`;
        a.click();
        window.URL.revokeObjectURL(url);
        
        setTimeout(() => Swal.close(), 600);
    } catch (err) {
        BioBrainUI.error('Download Failed', 'Could not generate the PDF.');
    }
}

  async function sendEmailReport(id) {
    if (typeof BioBrainUI === 'undefined') return console.error("Helper not loaded");

    BioBrainUI.showLoading('Sending Email', 'Generating PDF and dispatching to your inbox...');
    try {
        const response = await fetch(`/mocktest/result/email/${id}`);
        const data = await response.json();
        if (data.success) {
            BioBrainUI.finish();
             setTimeout(() => {
                BioBrainUI.success('Sent!', 'Check your email for the report.');
            }, 500);
        } else {
            throw new Error();
        }
    } catch (err) {
        BioBrainUI.error('Email Failed', 'We could not send the report at this time.');
    }
}

  // 📄 Analyse This Quiz (POST)
  async function analyzeQuiz(btn) {
    const box = document.getElementById("ai-summary");
    box.style.display = "block";
    //box.innerHTML = "⏳ Analyzing this quiz...";

    box.innerHTML = `
  <div class="loader desktop-quizresults-loader">
    <div class="hourglass desktop-quizresults-hourglass"></div>
    <span>Analyzing this quiz...</span>
  </div>
`;

    const resultid = btn.dataset.resultid;

    try {
      const res = await fetch("/aiassistant/singlequizsummary", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ resultid })
      });

      const data = await res.json();
      box.innerHTML = formatAI(data.explanation);

    } catch (err) {
      box.innerHTML = "❌ Failed to analyze quiz";
    }
  }

  // 📊 Analyse All Quizzes (POST)
  async function analyzeAll(btn) {
    const box = document.getElementById("ai-summary");
    box.style.display = "block";
    //box.innerHTML = "⏳ Analyzing all quizzes...";
    box.innerHTML = `
  <div class="loader desktop-quizresults-loader">
    <div class="hourglass desktop-quizresults-hourglass"></div>
    <span>Analyzing all quizzes...</span>
  </div>
`;

    const userid = btn.dataset.userid;

    try {
      const res = await fetch("/aiassistant/allquizsummary", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ userid })
      });

      const data = await res.json();
       // ✅ FIX HERE
    box.innerHTML = formatFullAnalysis(data.explanation);
//      box.innerHTML = formatAI(data.explanation);

    } catch (err) {
      box.innerHTML = "❌ Failed to analyze all quizzes";
    }
  }

  function formatAI(text) {
  return text
    .replace(/\n/g, "<br>")
    .replace(/\*\*/g, "") // remove markdown bold
    .replace(/###/g, "<br><strong>")
    .replace(/---/g, "<hr>");
}
 
  function formatFullAnalysis(data) {
  let html = "";

  html += `<h3>📊 Overall Accuracy: ${data.overallAccuracy.toFixed(1)}%</h3>`;

  if (data.strengths.length) {
    html += "<p>✅ <strong>Strengths:</strong><br>";
    data.strengths.forEach(s => {
      html += `✔️ ${s.topic} (${s.accuracy.toFixed(1)}%)<br>`;
    });
    html += "</p>";
  }

  if (data.weak.length) {
    html += "<p>❌ <strong>Weak Areas:</strong><br>";
    data.weak.forEach(w => {
      html += `👉 ${w.topic} (${w.accuracy.toFixed(1)}%)<br>`;
    });
    html += "</p>";
  }

  html += `<hr>${formatAI(data.aiSummary)}`;

  return html;
}

  async function explainAnswer(btn) {
      const box = btn.nextElementSibling;
      box.style.display = "block"; // show AI response
      //box.innerHTML = "⏳ Thinking...";

       box.innerHTML = `
  <div class="loader desktop-quizresults-loader">
    <div class="hourglass desktop-quizresults-hourglass"></div>
    <span>Thinking...</span>
  </div>
`;

      const payload = {
        question: btn.dataset.question,
        options: [
          btn.dataset.opt1,
          btn.dataset.opt2,
          btn.dataset.opt3,
          btn.dataset.opt4
        ],
        correctanswer: btn.dataset.correct,
        useranswer: btn.dataset.user
      };

      try {
        const res = await fetch("/aiassistant/explainanswer", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(payload)
        });

        const data = await res.json();
        box.innerHTML = data.explanation;

      } catch (err) {
        box.innerHTML = "❌ Failed to load explanation";
      }
    }
  
  function formatAI(text) {
    return text
      .replace(/\n/g, "<br>")
      .replace(/•/g, "✔️ ")
      .replace(/- /g, "👉 ");
    }
</script>
</body>
</html>