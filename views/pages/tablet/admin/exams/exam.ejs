<!DOCTYPE html>
<html>

<head>
<title>Admin Dashboard - Exams</title>

<link rel="stylesheet" href="/css/adminStyle.css">


</head>

<body class="view-pages-desktop-admin-exams-exam">

<%- include('../../../../partials/admin/header') %>

<div class="admin-container">

<%- include('../../../../partials/admin/sidebar') %>

<main class="admin-content">

<div class="exam-wrapper">

<div class="page-header">
📘 Exam Management
</div>

<div class="table-card">

<table>

<thead>

<tr>

<th>#</th>

<th>
Exam Name
<button class="sort-btn" onclick="sortTable(1)">⇅</button>
<select id="filterName" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
Exam Code
<button class="sort-btn" onclick="sortTable(2)">⇅</button>
<select id="filterCode" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th>
Created
<button class="sort-btn" onclick="sortTable(3)">⇅</button>
<select id="filterCreated" onchange="applyFilters()">
<option value="">All</option>
</select>
</th>

<th class="center">Actions</th>

</tr>

</thead>

<tbody id="examTableBody">

<% exams.forEach((exam,index)=>{ %>

<tr id="row-<%= exam._id %>">

<td class="center row-number"><%= index+1 %></td>

<td>
<span class="text-<%= exam._id %>"><%= exam.examname %></span>

<input type="text"
value="<%= exam.examname %>"
class="input-<%= exam._id %> admin-hidden">
</td>

<td><%= exam.examcode %></td>

<td><%= new Date(exam.createdAt).toLocaleDateString() %></td>

<td class="center action-buttons">

<button class="edit-btn"
onclick="enableEdit('<%= exam._id %>')">
Edit
</button>

<button class="save-btn admin-hidden"
onclick="saveEdit('<%= exam._id %>')">
Save
</button>

<button class="cancel-btn admin-hidden"
onclick="cancelEdit('<%= exam._id %>')">
Cancel
</button>

<button class="delete-btn"
onclick="deleteExam('<%= exam._id %>')">
Delete
</button>

</td>

</tr>

<% }) %>

<tr class="add-row" id="addRow">

<td class="center">+</td>

<td>
<input type="text"
id="newExamName"
placeholder="Exam Name">
</td>

<td>
<input type="text"
id="newExamCode"
placeholder="Exam Code">
</td>

<td>--</td>

<td class="center">
<button class="add-btn" onclick="addExam()">
Add
</button>
</td>

</tr>

</tbody>

</table>

</div>

</div>

</main>

</div>

<%- include('../../../../partials/admin/footer') %>

<script>

/* ======================
TABLE UTILITIES
====================== */

let sortDirection = {};

function refreshRowNumbers(){

const rows=document.querySelectorAll("#examTableBody tr:not(.add-row)");

rows.forEach((row,index)=>{
if(row.style.display!=="none")
row.querySelector(".row-number").innerText=index+1;
});

}

function rebuildFilters(){

const rows=document.querySelectorAll("#examTableBody tr:not(.add-row)");

const names=new Set();
const codes=new Set();
const dates=new Set();

rows.forEach(row=>{

if(row.style.display!=="none"){

names.add(row.children[1].innerText.trim());
codes.add(row.children[2].innerText.trim());
dates.add(row.children[3].innerText.trim());

}

});

buildDropdown("filterName",names);
buildDropdown("filterCode",codes);
buildDropdown("filterCreated",dates);

}

function buildDropdown(id,values){

const select=document.getElementById(id);
const current=select.value;

select.innerHTML='<option value="">All</option>';

Array.from(values).sort().forEach(val=>{

const option=document.createElement("option");
option.value=val;
option.textContent=val;

select.appendChild(option);

});

select.value=current;

}

function applyFilters(){

const nameF=document.getElementById("filterName").value;
const codeF=document.getElementById("filterCode").value;
const dateF=document.getElementById("filterCreated").value;

const rows=document.querySelectorAll("#examTableBody tr:not(.add-row)");

rows.forEach(row=>{

const name=row.children[1].innerText.trim();
const code=row.children[2].innerText.trim();
const date=row.children[3].innerText.trim();

let visible=true;

if(nameF && name!==nameF) visible=false;
if(codeF && code!==codeF) visible=false;
if(dateF && date!==dateF) visible=false;

row.style.display=visible ? "" : "none";

});

refreshRowNumbers();

}

function sortTable(col){

const table=document.getElementById("examTableBody");
const rows=Array.from(table.querySelectorAll("tr:not(.add-row)"));

sortDirection[col]=!sortDirection[col];

rows.sort((a,b)=>{

let A=a.children[col].innerText.toLowerCase();
let B=b.children[col].innerText.toLowerCase();

if(!isNaN(Date.parse(A))){
A=new Date(A);
B=new Date(B);
}

if(A<B) return sortDirection[col]?-1:1;
if(A>B) return sortDirection[col]?1:-1;

return 0;

});

rows.forEach(row=>table.insertBefore(row,document.getElementById("addRow")));

refreshRowNumbers();
rebuildFilters();

}

/* ======================
ROW EDITING
====================== */

function enableEdit(id){

document.querySelector('.text-'+id).style.display='none';
document.querySelector('.input-'+id).style.display='inline';

const row=document.getElementById('row-'+id);

row.querySelector('.edit-btn').style.display='none';
row.querySelector('.save-btn').style.display='inline';
row.querySelector('.cancel-btn').style.display='inline';

}

function cancelEdit(id){

document.querySelector('.text-'+id).style.display='inline';
document.querySelector('.input-'+id).style.display='none';

const row=document.getElementById('row-'+id);

row.querySelector('.edit-btn').style.display='inline';
row.querySelector('.save-btn').style.display='none';
row.querySelector('.cancel-btn').style.display='none';

}

function saveEdit(id){

const newName=document.querySelector('.input-'+id).value.trim();

if(!newName) return alert("Exam name required");

fetch(`/admin/exams/update/${id}`,{
method:"POST",
headers:{ "Content-Type":"application/json" },
body:JSON.stringify({ examname:newName })
})

.then(res=>res.json())

.then(data=>{

if(data.success){

document.querySelector('.text-'+id).innerText=newName;

cancelEdit(id);
rebuildFilters();

}
else alert("Update failed");

});

}

/* ======================
DELETE
====================== */

function deleteExam(id){

if(!confirm("Deleting this exam removes all related data. Continue?")) return;

fetch(`/admin/exams/delete/${id}`,{method:"POST"})
.then(()=>{

document.getElementById("row-"+id).remove();

refreshRowNumbers();
rebuildFilters();

});

}

/* ======================
ADD
====================== */

function addExam(){

const name=document.getElementById("newExamName").value.trim();
const code=document.getElementById("newExamCode").value.trim();

if(!name||!code)
return alert("All fields required");

fetch("/admin/exams/create",{

method:"POST",
headers:{ "Content-Type":"application/json" },

body:JSON.stringify({
examname:name,
examcode:code
})

})

.then(res=>res.json())

.then(data=>{

if(!data.success)
return alert(data.message);

const exam=data.exam;
const table=document.getElementById("examTableBody");

const row=document.createElement("tr");

row.id="row-"+exam._id;

row.innerHTML=`
<td class="center row-number">0</td>

<td>
<span class="text-${exam._id}">${exam.examname}</span>

<input type="text"
value="${exam.examname}"
class="input-${exam._id} admin-inline-rzfzxc">
</td>

<td>${exam.examcode}</td>

<td>${new Date(exam.createdAt).toLocaleDateString()}</td>

<td class="center action-buttons">

<button class="edit-btn"
onclick="enableEdit('${exam._id}')">
Edit
</button>

<button class="save-btn admin-inline-rzfzxc"
onclick="saveEdit('${exam._id}')">
Save
</button>

<button class="cancel-btn admin-inline-rzfzxc"
onclick="cancelEdit('${exam._id}')">
Cancel
</button>

<button class="delete-btn"
onclick="deleteExam('${exam._id}')">
Delete
</button>

</td>
`;

table.insertBefore(row,document.getElementById("addRow"));

document.getElementById("newExamName").value="";
document.getElementById("newExamCode").value="";

refreshRowNumbers();
rebuildFilters();

});

}

document.addEventListener("DOMContentLoaded",function(){
rebuildFilters();
});

</script>

</body>
</html>
