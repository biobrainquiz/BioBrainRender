<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BioBrain - Home</title>
    <link rel="stylesheet" href="/css/desktopStyle.css" />
    
</head>

<body class="desktop-index-page">
    <%- include('../../partials/desktop/header') %>

<div id="bio-bot-container">
    <div id="chat-window">
        <div id="chat-header">
            <span>Zoology Expert</span>
            <div id="header-actions">
                <button onclick="downloadChat()" title="Download as Text">💾</button>
                <button onclick="clearChat()" title="Clear Chat">🗑️</button>
                <button onclick="toggleChat()" title="Close">✖</button>
            </div>
        </div>
        
        <div id="messages">
            <div class="bot-msg desktop-index-bot-msg">Hello! Ask me any Zoology doubt. You can download our chat for your notes!</div>
        </div>

        <div class="input-area desktop-index-input-area">
            <input type="text" id="user-input" placeholder="Type your doubt...">
            <button id="send-btn" onclick="askGemini()">Ask</button>
        </div>
    </div>
    <div id="chat-bubble" onclick="toggleChat()" title="AI Bot">🧬</div>
</div>



<script>
    function toggleChat() {
        const win = document.getElementById('chat-window');
        win.style.display = (win.style.display === 'flex') ? 'none' : 'flex';
    }

    function clearChat() {
        if(confirm("Clear this conversation?")) {
            document.getElementById('messages').innerHTML = '<div class="bot-msg desktop-index-bot-msg">History cleared. How can I help with Zoology today?</div>';
        }
    }

    // 💾 Download Logic
    function downloadChat() {
        const msgDiv = document.getElementById('messages');
        const textContent = msgDiv.innerText;
        const blob = new Blob([textContent], { type: 'text/plain' });
        const anchor = document.createElement('a');
        anchor.download = "Zoology_Doubts_Notes.txt";
        anchor.href = (window.URL || window.webkitURL).createObjectURL(blob);
        anchor.click();
    }

    async function askGemini() {
        const input = document.getElementById('user-input');
        const msgDiv = document.getElementById('messages');
        const btn = document.getElementById('send-btn');
        const query = input.value.trim();

        if (!query) return;

        msgDiv.innerHTML += `<div class="user-msg desktop-index-user-msg">${query}</div>`;
        input.value = "";
        btn.disabled = true;
        btn.innerText = "⏳";
        msgDiv.scrollTop = msgDiv.scrollHeight;

        try {
            const response = await fetch('/aibot/ask-zoology-bot', {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ prompt: query })
            });

            const data = await response.json();
            
            if(data.answer) {
                // Formatting new lines for HTML display
                const htmlResponse = data.answer.replace(/\n/g, '<br>');
                msgDiv.innerHTML += `<div class="bot-msg desktop-index-bot-msg">${htmlResponse}</div>`;
            } else {
                msgDiv.innerHTML += `<div class="bot-msg desktop-index-inline-01 desktop-index-bot-msg">Error: AI limit reached or offline.</div>`;
            }
        } catch (err) {
            msgDiv.innerHTML += `<div class="bot-msg desktop-index-inline-01 desktop-index-bot-msg">Server connection failed.</div>`;
        } finally {
            btn.disabled = false;
            btn.innerText = "Ask";
            msgDiv.scrollTop = msgDiv.scrollHeight;
        }
    }

    document.getElementById('user-input').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') askGemini();
    });
</script>

        <!-- Hero Section -->
        <section class="hero desktop-index-hero">
            <div class="hero-overlay desktop-index-hero-overlay"></div>
            <h2>Master Life Sciences with Smart Quizzes</h2>
            <p>Challenge yourself with quizzes in Zoology, Botany, Genetics, Ecology & More.</p>
            <div>
                <button class="btn-primary desktop-index-btn-primary">Start Quiz</button>
                <button class="btn-secondary desktop-index-btn-secondary">View Leaderboard</button>
            </div>
        </section>

        <!-- Quiz Categories -->
        <section class="section desktop-index-section">
            <h3>Quiz Categories</h3>
            <div class="card-container desktop-index-card-container">
                <div class="card desktop-index-card">
                    <h4>NEET</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E1','S1')">Start</button>
                </div>
                <div class="card desktop-index-card">
                    <h4>DL/JL/Asst. Prof.</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E2','S1')">Start</button>
                </div>
                <div class="card desktop-index-card">
                    <h4>CSIR.NET/SLET/SET</h4>
                    <p>Life Sciences</p>
                    <button onclick="mockTest('E3','S2')">Start</button>
                </div>
                <div class="card desktop-index-card">
                    <h4>GATE</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E4','S1')">Start</button>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="section desktop-index-section">
            <h3>Why Choose BioBrain?</h3>
            <div class="features desktop-index-features">
                <div class="feature-box desktop-index-feature-box">✔ 1000+ MCQs across topics</div>
                <div class="feature-box desktop-index-feature-box">✔ Instant Results & Explanations</div>
                <div class="feature-box desktop-index-feature-box">✔ Track Your Progress</div>
                <div class="feature-box desktop-index-feature-box">✔ Compete on Leaderboard</div>
            </div>
        </section>

        <!-- Leaderboard Section -->
        <section class="leaderboard desktop-index-leaderboard">
            <h3>🏆 Top Biology Minds</h3>
            <table class="leaderboard-table desktop-index-leaderboard-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Name</th>
                        <th>Score</th>
                        <th>Accuracy</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (leaderboard && leaderboard.length> 0) { %>

                        <% leaderboard.forEach((user, index)=> { %>
                            <tr
                                class="<%= currentuser && currentuser._id.toString() === user._id.toString() ? 'current-user' : '' %>">
                                <td>
                                    <% if(index===0) { %> 🥇
                                        <% } else if(index===1) { %> 🥈
                                            <% } else if(index===2) { %> 🥉
                                                <% } else { %>
                                                    <%= index + 1 %>
                                                        <% } %>
                                </td>
                                <td>
                                    <%= user.username %>
                                </td>
                                <td>
                                    <%= user.finalscore %>
                                </td>
                                <td>
                                    <%= user.accuracy %>%
                                </td>
                            </tr>
                            <% }) %>

                                <% } else { %>
                                    <tr>
                                        <td colspan="4">No data available</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </section>

        <script>
            function mockTest(examcode, subjectcode) {
                window.location.href = `/mocktest/init/${examcode}/${subjectcode}`;
            }
        </script>
        </script>
        <%- include('../../partials/desktop/footer') %>
</body>

</html>