<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BioBrain - Home</title>
    <link rel="stylesheet" href="/css/laptopStyle.css" />

    
</head>

<body class="view-pages-tablet-index-copy-2">
    <%- include('../../partials/tablet/header') %>

        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-overlay"></div>
            <h2>Master Life Sciences with Smart Quizzes</h2>
            <p>Challenge yourself with quizzes in Zoology, Botany, Genetics, Ecology & More.</p>
            <div>
                <button class="btn-primary">Start Quiz</button>
                <button class="btn-secondary">View Leaderboard</button>
            </div>
        </section>

        <!-- Quiz Categories -->
        <section class="section">
            <h3>Quiz Categories</h3>
            <div class="card-container">
                <div class="card">
                    <h4>NEET</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E1','S1')">Start</button>
                </div>
                <div class="card">
                    <h4>DL/JL/Asst. Prof.</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E2','S1')">Start</button>
                </div>
                <div class="card">
                    <h4>CSIR.NET/SLET/SET</h4>
                    <p>Life Sciences</p>
                    <button onclick="mockTest('E3','S2')">Start</button>
                </div>
                <div class="card">
                    <h4>GATE</h4>
                    <p>Zoology</p>
                    <button onclick="mockTest('E4','S1')">Start</button>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="section">
            <h3>Why Choose BioBrain?</h3>
            <div class="features">
                <div class="feature-box">✔ 1000+ MCQs across topics</div>
                <div class="feature-box">✔ Instant Results & Explanations</div>
                <div class="feature-box">✔ Track Your Progress</div>
                <div class="feature-box">✔ Compete on Leaderboard</div>
            </div>
        </section>

        <!-- Leaderboard Section -->
        <section class="leaderboard">
            <h3>🏆 Top Biology Minds</h3>
            <table class="leaderboard-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Name</th>
                        <th>Score</th>
                        <th>Accuracy</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (leaderboard && leaderboard.length> 0) { %>
                        <% leaderboard.forEach((user, index)=> { %>
                            <tr
                                class="<%= currentuser && currentuser._id.toString() === user._id.toString() ? 'current-user' : '' %>">
                                <td>
                                    <span class="rank-box">
                                        <% if(index===0) { %> 🥇
                                            <% } else if(index===1) { %> 🥈
                                                <% } else if(index===2) { %> 🥉
                                                    <% } else { %> #<%= index + 1 %>
                                                            <% } %>
                                    </span>
                                </td>
                                <td class="laptop-inline-1ka1nmi">
                                    <%= user.username %>
                                        <% if(index===0) { %> <small class="laptop-inline-zjjwrb"
                                               >TOP GENIUS</small>
                                            <% } %>
                                </td>
                                <td class="laptop-inline-1b5wa92">
                                    <%= user.finalscore %>
                                </td>
                                <td>
                                    <div class="accuracy-bar-bg">
                                        <div class="accuracy-bar-fill pct-width pct-<%= Math.max(0, Math.min(100, Math.round(Number(user.accuracy) || 0))) %>"></div>
                                    </div>
                                    <%= user.accuracy %>%
                                </td>
                            </tr>
                            <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td class="laptop-inline-1hbcky3" colspan="4">No brilliant minds
                                            yet. Be the first!</td>
                                    </tr>
                                    <% } %>
                </tbody>
            </table>
        </section>

        <script>
            function mockTest(examcode, subjectcode) {
                window.location.href = `/mocktest/init/${examcode}/${subjectcode}`;
            }
        </script>
        </script>
        <%- include('../../partials/tablet/footer') %>
</body>

</html>