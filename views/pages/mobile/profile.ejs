<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>BioBrain | Profile</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/mobileStyle.css">

    
</head>

<body class="view-pages-mobile-profile">

<%- include('../../partials/mobile/header') %>

<div class="profile-wrapper">
<div class="container">

    <!-- USER INFO -->
    <div class="profile-card">
        <div>
            <h2><%= user.username %></h2>

            <p><strong>Email:</strong> <%= user.email || 'N/A' %></p>

            <p><strong>Member Since:</strong> 
                <%= user.userCreatedOn ? new Date(user.userCreatedOn).toDateString() : 'N/A' %>
            </p>

            <p><strong>Roles:</strong> 
                <%= user.roles.map(role => role.role || role).join(', ') %>
            </p>
        </div>

        <div class="badge">BioBrain Explorer 🚀</div>
    </div>

    <!-- STATS -->
    <div class="stats-grid">
        <div class="stat-box"><h4>Quizzes</h4><span><%= stats.totalQuizzes || 0 %></span></div>
        <div class="stat-box"><h4>Total Score</h4><span><%= stats.totalScore || 0 %></span></div>
        <div class="stat-box"><h4>Average</h4><span><%= stats.averageScore || 0 %></span></div>
        <div class="stat-box"><h4>Highest</h4><span><%= stats.highestScore || 0 %></span></div>
        <div class="stat-box"><h4>Lowest</h4><span><%= stats.lowestScore || 0 %></span></div>
        <div class="stat-box"><h4>Accuracy</h4><span><%= stats.overallAccuracy || 0 %>%</span></div>
    </div>

    <!-- PERFORMANCE + CHART -->
    <div class="performance-row">

        <div class="section half-card">
            <h3>Overall Performance (<%= stats.overallAccuracy || 0 %>%)</h3>

            <div class="progress-container">
                <div class="progress-bar pct-width pct-<%= Math.max(0, Math.min(100, Math.round(Number(Math.min(stats.overallAccuracy || 0, 100)) || 0))) %>"></div>
            </div>
        </div>

        <div class="section half-card">
            <h3>Score Trend</h3>
            <div class="chart-container">
                <canvas id="scoreChart"></canvas>
            </div>
        </div>

    </div>

</div>
</div>

<%- include('../../partials/mobile/footer') %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const quizData = <%- JSON.stringify(quizHistory ?? []) %>;

    if (quizData.length) {
        const labels = quizData.map(q => new Date(q.createdAt).toLocaleDateString());
        const scores = quizData.map(q => q.finalscore || 0);

        new Chart(document.getElementById('scoreChart'), {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Score',
                    data: scores,
                    borderColor: '#38bdf8',
                    backgroundColor: 'rgba(14,165,233,0.2)',
                    fill: true,
                    tension: 0.4
                }]
            }
        });
    }
</script>

</body>
</html>