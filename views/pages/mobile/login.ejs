<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BioBrain - Login</title>
  <link rel="stylesheet" href="/css/mobileStyle.css" />
</head>

<body class="mobile-login-page">
  <!-- Header Include -->
  <%- include('../../partials/mobile/header') %>

    <div class="login-container mobile-login-container">
      <h2>Sign In</h2>

      <!--<input type="text" id="username" placeholder="Username" />-->
      <input type="text" id="identifier" placeholder="Username / Email / Mobile" />
      <input type="password" id="password" placeholder="Password" />

      <div class="captcha-container mobile-login-captcha-container">
        <div class="captcha mobile-login-captcha" id="captcha"></div>
        <button id="refreshCaptcha">↻</button>
      </div>
      <input type="text" id="captchaInput" placeholder="Enter CAPTCHA" />

      <button id="loginBtn">Login</button>

      <div class="links mobile-login-links">
        <a href="/authentication/forgot">Forgot Password</a>
        <a href="/authentication/register">Register</a>
        <a href="/authentication/resend-link-page">Resend Verification</a>
      </div>

      <div class="mobile-login-inline-01" id="resendContainer">
          <p class="mobile-login-inline-02">Didn't get the link?</p>
              <button class="mobile-login-inline-03" id="resendBtn">
                  Resend Verification Email
              </button>
      </div>

      <div class="error mobile-login-error" id="errorMsg"></div>
    </div>

    <script>
      // Simple CAPTCHA generation
      function generateCaptcha() {
        const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
        let captcha = "";
        for (let i = 0; i < 5; i++) {
          captcha += chars.charAt(Math.floor(Math.random() * chars.length));
        }
        return captcha;
      }

      let currentCaptcha = generateCaptcha();
      document.getElementById("captcha").innerText = currentCaptcha;

      document.getElementById("refreshCaptcha").addEventListener("click", () => {
        currentCaptcha = generateCaptcha();
        document.getElementById("captcha").innerText = currentCaptcha;
      });

      // Login button click
      
document.getElementById("loginBtn").addEventListener("click", async () => {
  const identifier = document.getElementById("identifier").value;
  const password = document.getElementById("password").value;
  const captchaInput = document.getElementById("captchaInput").value;
  const errorMsg = document.getElementById("errorMsg");
  const resendContainer = document.getElementById("resendContainer"); // New reference

  errorMsg.innerText = "";
  resendContainer.style.display = "none"; // Hide resend on new attempt

  if (!identifier || !password || !captchaInput) {
    errorMsg.innerText = "All fields are required!";
    return;
  }

  if (captchaInput.toUpperCase() !== currentCaptcha) {
    errorMsg.innerText = "CAPTCHA does not match!";
    return;
  }

  try {
    const res = await fetch("/authentication/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ identifier, password })
    });

    const data = await res.json();

    if (data.success) {
      window.location.href = data.redirect;
    } else {
      errorMsg.innerText = data.message;

      // Check if backend returned the verification error
      if (data.message.toLowerCase().includes("verify your email")) {
        resendContainer.style.display = "block";
        
        // Attach the email returned from backend to the resend button
        // (Assumes you added 'email: user.email' to the login controller response)
        window.pendingVerificationEmail = data.email; 
      }
    }
  } catch (e) {
    errorMsg.innerText = "Server error!";
  }
});

// NEW: Handle Resend Button Click
document.getElementById("resendBtn").addEventListener("click", async () => {
  const errorMsg = document.getElementById("errorMsg");
  const resendBtn = document.getElementById("resendBtn");
  
  errorMsg.innerText = "Sending verification email...";
  resendBtn.disabled = true;

  try {
    const res = await fetch("/authentication/resend-verification", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email: window.pendingVerificationEmail })
    });

    const data = await res.json();
    errorMsg.style.color = data.success ? "green" : "red";
    errorMsg.innerText = data.message;
    
    if (data.success) {
      document.getElementById("resendContainer").style.display = "none";
    }
  } catch (e) {
    errorMsg.innerText = "Error resending email.";
  } finally {
    resendBtn.disabled = false;
  }
});



    </script>

    <!-- Footer Include -->
    <%- include('../../partials/mobile/footer') %>
</body>

</html>